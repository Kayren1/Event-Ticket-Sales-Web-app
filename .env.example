# Django Settings
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,yourapp-name.vercel.app

# Database Configuration (Supabase PostgreSQL)
# Get your DATABASE_URL from Supabase dashboard:
# https://app.supabase.com → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Supabase Configuration
# Get these from https://app.supabase.com → Project Settings → API Keys
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
POSTGRES_PASSWORD=your_postgres_password_here

# Stripe Keys (get from Stripe dashboard)
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Celery Configuration
# For development with local Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db

# For production with cloud Redis (e.g., Redis Cloud, AWS ElastiCache)
# CELERY_BROKER_URL=redis://username:password@host:port/0
# CELERY_RESULT_BACKEND=redis://username:password@host:port/0

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@paperweight.com

# CSRF Trusted Origins
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://yourapp-name.vercel.app

# Optional: Security headers and HTTPS
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Optional: Static files storage
# Set to 'True' if using cloud storage (S3, etc.)
USE_CLOUD_STORAGE=False
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=your-bucket-name
