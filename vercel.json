{
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "devCommand": "python manage.py runserver 0.0.0.0:8000",
  "env": {
    "DJANGO_SETTINGS_MODULE": "paperweight.settings"
  },
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/static/(?P<filename>.*)",
      "dest": "/static/$filename"
    },
    {
      "src": "/media/(?P<filename>.*)",
      "dest": "/media/$filename"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
